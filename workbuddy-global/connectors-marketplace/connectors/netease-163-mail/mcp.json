{
  "mcpServers": {
    "netease-163-mail": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-email"
      ],
      "env": {
        "EMAIL_USER": "${EMAIL_USER}",
        "EMAIL_PASSWORD": "${EMAIL_PASSWORD}",
        "EMAIL_TYPE": "163"
      }
    }
  }
}
